<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Google Play policy: REQUEST_INSTALL_PACKAGES is not allowed for apps
        whose core purpose is not app installation/management.
        tools:node="remove" strips this from the merged manifest for the
        stable (Google Play) flavor only. All other flavors keep it.
    -->
    <uses-permission
        android:name="android.permission.REQUEST_INSTALL_PACKAGES"
        tools:node="remove" />

    <!-- Bluetooth / Nearby devices: unused in Sono -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        tools:node="remove" />

</manifest>
